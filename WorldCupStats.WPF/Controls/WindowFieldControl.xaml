<UserControl x:Class="WorldCupStats.WPF.Controls.PlayerFieldControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="120" Height="80" Margin="3"
             Cursor="Hand">

    <Border Background="#1a3d0a" CornerRadius="6"
            BorderBrush="White" BorderThickness="1">
        <StackPanel VerticalAlignment="Center" 
                    HorizontalAlignment="Center">
            <Ellipse Width="35" Height="35" 
                     HorizontalAlignment="Center">
                <Ellipse.Fill>
                    <ImageBrush x:Name="imgPlayer" 
                                Stretch="UniformToFill"/>
                </Ellipse.Fill>
            </Ellipse>
            <TextBlock x:Name="lblName" 
                       Foreground="White" 
                       FontSize="9"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       MaxWidth="110"/>
            <TextBlock x:Name="lblNumber" 
                       Foreground="Yellow"
                       FontSize="9"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>