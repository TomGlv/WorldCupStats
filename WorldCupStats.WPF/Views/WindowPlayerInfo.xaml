<Window x:Class="WorldCupStats.WPF.Views.WindowPlayerInfo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Player Info" Height="400" Width="350"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="30">
        <Ellipse Width="100" Height="100" 
                 HorizontalAlignment="Center"
                 Margin="0,0,0,15">
            <Ellipse.Fill>
                <ImageBrush x:Name="imgPlayer" 
                            Stretch="UniformToFill"/>
            </Ellipse.Fill>
        </Ellipse>

        <TextBlock x:Name="lblName" FontSize="18" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <Grid HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" 
                       Text="Number:" FontWeight="Bold"/>
            <TextBlock x:Name="lblNumber" 
                       Grid.Row="0" Grid.Column="1"/>

            <TextBlock Grid.Row="1" Grid.Column="0" 
                       Text="Position:" FontWeight="Bold"/>
            <TextBlock x:Name="lblPosition" 
                       Grid.Row="1" Grid.Column="1"/>

            <TextBlock Grid.Row="2" Grid.Column="0" 
                       Text="Captain:" FontWeight="Bold"/>
            <TextBlock x:Name="lblCaptain" 
                       Grid.Row="2" Grid.Column="1"/>

            <TextBlock Grid.Row="3" Grid.Column="0" 
                       Text="Favorite:" FontWeight="Bold"/>
            <TextBlock x:Name="lblFavorite" 
                       Grid.Row="3" Grid.Column="1"/>
        </Grid>
    </StackPanel>
</Window>